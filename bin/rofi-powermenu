#!/usr/bin/env bash

chosen=$(printf "Poweroff\nReboot\nLog Out" | rofi -dmenu -i -cycle -hover-select -me-select-entry '' -me-accept-entry MousePrimary -theme-str '
horibox {
    children:   [ listview ];
}
window {
    width: 100%;                     
}
element {
    cursor: pointer;
}
element-text{
    cursor: pointer;
}
')

case "$chosen" in
"Poweroff")
    poweroff
    ;;
"Reboot")
    reboot
    ;;
"Log Out")
    bspc quit
    ;;
*)
    exit 1
    ;;
esac
